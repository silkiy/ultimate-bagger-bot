{
    "version": 2,
    "crons": [
        {
            "path": "/api/cron",
            "schedule": "0 3 * * 1-5"
        },
        {
            "path": "/api/cron",
            "schedule": "45 8 * * 1-5"
        }
    ],
    "routes": [
        {
            "src": "/api/webhook",
            "dest": "/api/webhook.ts"
        },
        {
            "src": "/api/cron",
            "dest": "/api/cron.ts"
        },
        {
            "src": "/api/health",
            "dest": "/api/health.ts"
        },
        {
            "src": "/",
            "dest": "/public/index.html"
        }
    ],
    "functions": {
        "api/*.ts": {
            "memory": 1024,
            "maxDuration": 60
        }
    }
}